import os
import time
import secrets
import json
import logging
from datetime import datetime, timedelta
from functools import wraps

from flask import Flask, request, jsonify, render_template, session, redirect, url_for
from flask_limiter import Limiter
from flask_limiter.util import get_remote_address
from flask_cors import CORS
import requests
import stripe
import redis
import bcrypt
import jwt
from dotenv import load_dotenv

# Database
from models import db, User, ApiKey, ConversionLog

load_dotenv()
app = Flask(__name__)
app.config['SECRET_KEY'] = os.getenv('SECRET_KEY', secrets.token_hex(32))

# Database setup
database_url = os.getenv('DATABASE_URL')
if database_url and database_url.startswith('postgres://'):
    database_url = database_url.replace('postgres://', 'postgresql://', 1)
app.config['SQLALCHEMY_DATABASE_URI'] = database_url or 'sqlite:///webhooker.db'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False
db.init_app(app)

# Create tables on startup
with app.app_context():
    db.create_all()

# CORS
CORS(app)

# Stripe
stripe.api_key = os.getenv('STRIPE_KEY')
if not stripe.api_key:
    app.logger.warning("STRIPE_KEY not set – billing will fail")

# Redis for rate limiting and fast key lookup
redis_url = os.getenv('REDIS_URL', None)
if redis_url:
    try:
        r = redis.Redis.from_url(redis_url, decode_responses=True)
        r.ping()
    except Exception as e:
        r = None
        app.logger.warning(f"Redis connection failed: {e}, rate limiting will use memory")
else:
    r = None
    app.logger.warning("REDIS_URL not set – rate limiting will use memory")

# Rate limiter
limiter = Limiter(
    app=app,
    key_func=get_remote_address,
    default_limits=["500 per hour"],
    storage_uri=redis_url or "memory://",
    strategy="fixed-window"
)

# JWT config
JWT_SECRET = os.getenv('JWT_SECRET', app.config['SECRET_KEY'])
JWT_ALGORITHM = 'HS256'
JWT_EXP_DELTA_HOURS = 24

logging.basicConfig(level=logging.INFO)

# ------------------- Helper Functions -------------------

def token_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        token = None
        # Check header first
        auth_header = request.headers.get('Authorization')
        if auth_header and auth_header.startswith('Bearer '):
            token = auth_header.split(' ')[1]
        # Fallback to cookie (for browser dashboard)
        if not token and 'jwt_token' in session:
            token = session['jwt_token']
        
        if not token:
            return jsonify({'error': 'Token missing'}), 401
        
        try:
            data = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGORITHM])
            current_user = User.query.get(data['user_id'])
            if not current_user:
                return jsonify({'error': 'Invalid user'}), 401
        except jwt.ExpiredSignatureError:
            return jsonify({'error': 'Token expired'}), 401
        except jwt.InvalidTokenError:
            return jsonify({'error': 'Invalid token'}), 401
        
        return f(current_user, *args, **kwargs)
    return decorated

# ------------------- Auth Routes -------------------

@app.route('/api/register', methods=['POST'])
def register():
    data = request.get_json()
    email = data.get('email')
    password = data.get('password')
    target_url = data.get('target_url')  # optional first key target
    
    if not email or not password:
        return jsonify({'error': 'Email and password required'}), 400
    
    if User.query.filter_by(email=email).first():
        return jsonify({'error': 'Email already registered'}), 409
    
    # Create user
    user = User(email=email)
    user.set_password(password)
    
    # Create Stripe customer
    try:
        customer = stripe.Customer.create(email=email)
        user.stripe_customer_id = customer.id
    except Exception as e:
        app.logger.error(f"Stripe customer creation failed: {e}")
        # Continue – can add payment later
    
    db.session.add(user)
    db.session.flush()  # get user.id
    
    # Create initial API key if target_url provided
    if target_url:
        api_key = secrets.token_urlsafe(32)
        new_key = ApiKey(
            key=api_key,
            user_id=user.id,
            target_url=target_url
        )
        db.session.add(new_key)
        # Also store in Redis for fast lookup
        if r:
            r.set(f"key:{api_key}", json.dumps({
                'user_id': user.id,
                'target_url': target_url,
                'config': {}
            }))
    else:
        api_key = None
    
    db.session.commit()
    
    # Generate JWT token
    token = jwt.encode({
        'user_id': user.id,
        'email': user.email,
        'exp': datetime.utcnow() + timedelta(hours=JWT_EXP_DELTA_HOURS)
    }, JWT_SECRET, algorithm=JWT_ALGORITHM)
    
    return jsonify({
        'token': token,
        'api_key': api_key,
        'user': {'email': user.email, 'id': user.id}
    })

@app.route('/api/login', methods=['POST'])
def login():
    data = request.get_json()
    email = data.get('email')
    password = data.get('password')
    
    if not email or not password:
        return jsonify({'error': 'Email and password required'}), 400
    
    user = User.query.filter_by(email=email).first()
    if not user or not user.check_password(password):
        return jsonify({'error': 'Invalid credentials'}), 401
    
    token = jwt.encode({
        'user_id': user.id,
        'email': user.email,
        'exp': datetime.utcnow() + timedelta(hours=JWT_EXP_DELTA_HOURS)
    }, JWT_SECRET, algorithm=JWT_ALGORITHM)
    
    # Set session cookie for browser
    session['jwt_token'] = token
    
    return jsonify({
        'token': token,
        'user': {'email': user.email, 'id': user.id}
    })

@app.route('/api/logout', methods=['POST'])
def logout():
    session.pop('jwt_token', None)
    return jsonify({'message': 'Logged out'})

@app.route('/api/me', methods=['GET'])
@token_required
def get_me(current_user):
    return jsonify({
        'email': current_user.email,
        'stripe_customer_id': current_user.stripe_customer_id,
        'created_at': current_user.created_at.isoformat(),
        'api_keys_count': current_user.api_keys.count()
    })

# ------------------- API Key Management -------------------

@app.route('/api/keys', methods=['GET'])
@token_required
def list_keys(current_user):
    keys = []
    for key in current_user.api_keys.filter_by(is_active=True).all():
        keys.append({
            'id': key.id,
            'key': key.key,
            'target_url': key.target_url,
            'config': key.config,
            'created_at': key.created_at.isoformat(),
            'last_used': key.last_used.isoformat() if key.last_used else None
        })
    return jsonify(keys)

@app.route('/api/keys', methods=['POST'])
@token_required
def create_key(current_user):
    data = request.get_json()
    target_url = data.get('target_url')
    if not target_url:
        return jsonify({'error': 'target_url required'}), 400
    
    api_key = secrets.token_urlsafe(32)
    new_key = ApiKey(
        key=api_key,
        user_id=current_user.id,
        target_url=target_url,
        config=data.get('config', {})
    )
    db.session.add(new_key)
    db.session.commit()
    
    # Store in Redis
    if r:
        r.set(f"key:{api_key}", json.dumps({
            'user_id': current_user.id,
            'target_url': target_url,
            'config': data.get('config', {})
        }))
    
    return jsonify({'api_key': api_key, 'id': new_key.id})

@app.route('/api/keys/<int:key_id>', methods=['DELETE'])
@token_required
def delete_key(current_user, key_id):
    key = ApiKey.query.filter_by(id=key_id, user_id=current_user.id).first()
    if not key:
        return jsonify({'error': 'Key not found'}), 404
    
    key.is_active = False
    db.session.commit()
    
    # Remove from Redis (or mark inactive)
    if r:
        r.delete(f"key:{key.key}")
    
    return jsonify({'message': 'Key deactivated'})

# ------------------- Conversion Logs -------------------

@app.route('/api/logs', methods=['GET'])
@token_required
def get_logs(current_user):
    # Pagination
    page = request.args.get('page', 1, type=int)
    per_page = request.args.get('per_page', 20, type=int)
    
    logs_query = current_user.conversions.order_by(ConversionLog.timestamp.desc())
    paginated = logs_query.paginate(page=page, per_page=per_page, error_out=False)
    
    logs = []
    for log in paginated.items:
        logs.append({
            'id': log.id,
            'timestamp': log.timestamp.isoformat(),
            'response_code': log.response_code,
            'success': log.success,
            'charge_amount': float(log.charge_amount) if log.charge_amount else None,
            'target_url': log.target_url,
            'duration_ms': log.duration_ms,
            'api_key_id': log.api_key_id
        })
    
    return jsonify({
        'logs': logs,
        'total': paginated.total,
        'page': page,
        'pages': paginated.pages
    })

@app.route('/api/logs/stats', methods=['GET'])
@token_required
def get_stats(current_user):
    today = datetime.utcnow().date()
    # This week stats
    week_ago = today - timedelta(days=7)
    
    total_conv = current_user.conversions.count()
    success_conv = current_user.conversions.filter_by(success=True).count()
    total_charged = db.session.query(db.func.sum(ConversionLog.charge_amount))\
        .filter(ConversionLog.user_id == current_user.id).scalar() or 0
    
    recent = current_user.conversions.filter(ConversionLog.timestamp >= week_ago).count()
    
    return jsonify({
        'total_conversions': total_conv,
        'successful_conversions': success_conv,
        'total_charged': float(total_charged),
        'last_7_days': recent
    })

