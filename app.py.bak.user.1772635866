    """Legacy registration endpoint – now forwards to /api/register with minor adaptation."""
    # For backward compatibility, but we encourage using /api/register
    data = request.get_json()
    email = data.get('email')
    target_url = data.get('target_url')
    # No password? We'll generate a random one and email? Not ideal.
    # Instead, we'll require password. This endpoint should be deprecated.
    # For now, return 400 with message.
    return jsonify({'error': 'Please use /api/register with password'}), 400

@app.route('/convert', methods=['POST'])
def convert_webhook():
    """Main webhook conversion endpoint – now logs to database."""
    api_key = request.headers.get('X-API-Key')
    if not api_key:
        return jsonify({"error": "Missing API key"}), 401
    
    # Look up key in Redis first (fast path)
    key_data = None
    if r:
        key_json = r.get(f"key:{api_key}")
        if key_json:
            key_data = json.loads(key_json)
    
    # Fallback to database
    if not key_data:
        key_obj = ApiKey.query.filter_by(key=api_key, is_active=True).first()
        if not key_obj:
            return jsonify({"error": "Invalid API key"}), 401
        
        key_data = {
            'user_id': key_obj.user_id,
            'target_url': key_obj.target_url,
            'config': key_obj.config
        }
        # Populate Redis for next time
        if r:
            r.set(f"key:{api_key}", json.dumps(key_data))
    
    user_id = key_data['user_id']
    target_url = key_data['target_url']
    config = key_data.get('config', {})
    
    start_time = time.time()
    transformed_data = request.get_json()  # apply transformations based on config
    success = True
    response_code = None
    
    try:
        response = requests.post(target_url, json=transformed_data, timeout=10)
        response_code = response.status_code
        success = 200 <= response_code < 300
        
        # Record usage for Stripe metered billing
        user = User.query.get(user_id)
        if user and user.stripe_customer_id and stripe.api_key:
            # We need subscription_item_id – currently not stored.
            # This is a placeholder – you'll need to store subscription_item_id per user.
            pass  # implement as needed
        
    except Exception as e:
        app.logger.error(f"Conversion error: {e}")
        success = False
        response_code = 500
    
    duration = int((time.time() - start_time) * 1000)
    
    # Log to database (async would be better but ok for now)
    try:
        # Find the ApiKey id
        key_obj = ApiKey.query.filter_by(key=api_key).first()
        if key_obj:
            log = ConversionLog(
                user_id=user_id,
                api_key_id=key_obj.id,
                response_code=response_code,
                success=success,
                charge_amount=0.01 if success else None,  # adjust based on pricing
                duration_ms=duration,
                target_url=target_url,
                request_preview=str(transformed_data)[:500]
            )
            db.session.add(log)
            
            # Update last_used on key
            key_obj.last_used = datetime.utcnow()
            db.session.commit()
    except Exception as e:
        app.logger.error(f"Logging failed: {e}")
        db.session.rollback()
    
    return jsonify({"status": "success" if success else "error", "response_code": response_code})

@app.route('/health')
def health():
    redis_status = "connected" if r and r.ping() else "disconnected (using memory)"
    db_status = "connected"
    try:
        db.session.execute('SELECT 1')
    except:
        db_status = "disconnected"
    return jsonify({
        "status": "healthy",
        "redis": redis_status,
        "database": db_status
    })

